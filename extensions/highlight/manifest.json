{
  "manifest_version": 3,
  "name": "文本高亮工具",
  "version": "1.1",
  "description": "在网页上高亮选中文本 - 支持多种颜色",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
